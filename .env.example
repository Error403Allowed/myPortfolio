# Chat endpoint used by the browser
VITE_CHAT_API_URL=/api/chat

# Groq model (optional — defaults to llama-4-scout)
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# CORS origin for the chat proxy in local dev
CHAT_ALLOWED_ORIGIN=http://localhost:8080

# Add one or more Groq API keys (round-robin load balanced)
# Get yours at https://console.groq.com
GROQ_API_KEY_1=
GROQ_API_KEY_2=

# Mail config (Formspree)
# 1. Go to https://formspree.io/ and create a free account
# 2. Create a new form and get your endpoint URL
# 3. It looks like: https://formspree.io/f/yourFormId
FORMSPREE_ENDPOINT=https://formspree.io/f/yourFormId
